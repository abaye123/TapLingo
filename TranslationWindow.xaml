<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TapLingo.TranslationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TapLingo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Padding="0">
        <!-- פונקציית Mica / Acrylic מוגדרת בקוד (SystemBackdrop) -->

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- TitleBar מותאם -->
            <RowDefinition Height="Auto"/>  <!-- טקסט מקור -->
            <RowDefinition Height="*"/>     <!-- תרגום -->
            <RowDefinition Height="Auto"/>  <!-- סרגל תחתון -->
        </Grid.RowDefinitions>

        <!-- TitleBar מותאם עם אזור גרירה -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <!-- לוגו האפליקציה -->
                <Image Source="Assets/AppIcon.png"
                       Width="20" Height="20"
                       VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleText"
                           Text="תרגום מהיר"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="10"
                        Padding="8,2"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="EngineLabel"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               FontSize="10"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- כרטיס טקסט מקור -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Margin="16,4,16,6"
                Padding="14,10">
            <StackPanel Spacing="6">
                <TextBlock Text="טקסט מקור"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ScrollViewer MaxHeight="90"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBox x:Name="SourceTextBox"
                             BorderThickness="0"
                             Background="Transparent"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Padding="0"
                             FontSize="13"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- כרטיס תוצאת התרגום -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Margin="16,6,16,6"
                Padding="14,10">
            <Grid>
                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="תרגום"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Grid.Column="1"
                                   x:Name="DetectedLangLabel"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="220">
                        <TextBox x:Name="TranslatedTextBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 Padding="0"
                                 FontSize="15"/>
                    </ScrollViewer>
                </StackPanel>

                <!-- אינדיקטור טעינה (Fluent ProgressRing מובנה!) -->
                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <ProgressRing IsActive="True"
                                  Width="36"
                                  Height="36"/>
                    <TextBlock Text="מתרגם..."
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- סרגל פעולות תחתון -->
        <Grid Grid.Row="3" Margin="16,6,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="TargetLangCombo"
                      Grid.Column="0"
                      Width="150"
                      Height="32"
                      SelectionChanged="TargetLangCombo_SelectionChanged"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button x:Name="CopyButton" Click="CopyButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                        <TextBlock Text="העתק"/>
                    </StackPanel>
                </Button>
                <Button x:Name="RetranslateButton" Click="RetranslateButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="תרגם שוב"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SettingsButton" Click="SettingsButton_Click"
                        ToolTipService.ToolTip="הגדרות">
                    <FontIcon Glyph="&#xE713;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
